# Server
PORT=3001                                   # Express listen port
NODE_ENV=development                        # development | production
CORS_ORIGINS=http://localhost:3000          # comma-separated allowed origins

# Firebase Admin credentials - use EITHER the file path OR the three inline vars below.
GOOGLE_APPLICATION_CREDENTIALS=./serviceAccount.json   # path to the service-account JSON

# Inline service-account fields (alternative to the path above)
FIREBASE_PROJECT_ID=your-project-id         # Firebase project id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com   # service-account email
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"   # PEM key; keep literal \n escapes
