rules_version = '2';

// All Firestore access in this app goes through the Express backend using the
// Firebase Admin SDK, which runs with privileged credentials and bypasses these
// rules entirely. Clients never connect to Firestore directly, so direct client
// access is denied. This is defense in depth: even if a client obtained the web
// config, it could not read or write the database.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

// Alternative rules, kept for reference. If direct client access is ever added
// (frontend talking to Firestore via the client SDK instead of through Express),
// remove the deny-all service block above and use these per-user owner rules so a
// signed-in user can only touch their own subtree under users/{uid}:
//
// service cloud.firestore {
//   match /databases/{database}/documents {
//     match /users/{uid} {
//       allow read, write: if request.auth != null && request.auth.uid == uid;
//       match /{collection}/{docId} {
//         allow read, write: if request.auth != null && request.auth.uid == uid;
//       }
//     }
//   }
// }
