# Frontend Environment Configuration
# Budget Tracker - API Integration Settings

# =============================================================================
# FIREBASE CONFIGURATION
# =============================================================================

REACT_APP_FIREBASE_API_KEY=AIzaSyDoR4bZFfovdfs-jmPLVbCNAxWrqCAtLJU
REACT_APP_FIREBASE_AUTH_DOMAIN=budget-tracker-839a9.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=budget-tracker-839a9
REACT_APP_FIREBASE_STORAGE_BUCKET=budget-tracker-839a9.firebasestorage.app
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=340731276059
REACT_APP_FIREBASE_APP_ID=1:340731276059:web:d6837f9542e7ff867601be

# =============================================================================
# API CONFIGURATION
# =============================================================================

# Enable API mode (set to 'true' to use backend API, 'false' to use localStorage)
REACT_APP_USE_API=false

# Backend API Configuration
REACT_APP_API_URL=http://localhost:3001/api
REACT_APP_API_TIMEOUT=10000

# Health Check Endpoint
REACT_APP_HEALTH_ENDPOINT=http://localhost:3001/health

# =============================================================================
# DEVELOPMENT SETTINGS
# =============================================================================

# Development Mode
NODE_ENV=development

# Enable Debug Logging
REACT_APP_DEBUG=true

# Browser Dev Tools
REACT_APP_ENABLE_REDUX_DEVTOOLS=true

# =============================================================================
# OFFLINE MODE CONFIGURATION
# =============================================================================

# Enable offline support (automatic fallback to localStorage when API is unavailable)
REACT_APP_ENABLE_OFFLINE=true

# Offline sync retry attempts
REACT_APP_OFFLINE_RETRY_ATTEMPTS=3

# Offline sync retry delay (milliseconds)
REACT_APP_OFFLINE_RETRY_DELAY=5000

# =============================================================================
# CACHING CONFIGURATION
# =============================================================================

# Enable client-side caching
REACT_APP_ENABLE_CACHE=true

# Cache expiry time (milliseconds) - 5 minutes
REACT_APP_CACHE_EXPIRY=300000

# =============================================================================
# ERROR HANDLING
# =============================================================================

# Show detailed error messages in development
REACT_APP_SHOW_ERROR_DETAILS=true

# Enable error reporting
REACT_APP_ENABLE_ERROR_REPORTING=false

# =============================================================================
# PERFORMANCE SETTINGS
# =============================================================================

# Pagination default page size
REACT_APP_DEFAULT_PAGE_SIZE=20

# Maximum page size
REACT_APP_MAX_PAGE_SIZE=100

# Request debounce delay (milliseconds)
REACT_APP_DEBOUNCE_DELAY=300
